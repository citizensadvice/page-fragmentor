{
  "name": "@citizensadvice/page-fragmenter",
  "version": "2.0.0",
  "description": "Split a HTML page into printable pages",
  "scripts": {
    "format": "prettier --write .",
    "lint:format": "prettier --check .",
    "lint:js": "eslint",
    "lint:css": "stylelint **/*.css",
    "lint": "npm run lint:format && npm run lint:js && npm run lint:css",
    "test": "node --test src/**/*.test.js",
    "start-playwright-image": "docker run --rm --init --network=host --add-host=hostmachine:host-gateway --workdir /home/pwuser --user pwuser mcr.microsoft.com/playwright:v1.60.0-noble /bin/sh -c \"npx -y playwright@1.60.0 run-server --port 5001 --host 0.0.0.0\"",
    "playwright": "start-server-and-test start-playwright-image tcp:5001 'PW_TEST_CONNECT_WS_ENDPOINT=ws://127.0.0.1:5001/ npx playwright test --quiet'",
    "playwright:ui": "start-server-and-test start-playwright-image tcp:5001 'PW_TEST_CONNECT_WS_ENDPOINT=ws://127.0.0.1:5001/ npx playwright test --ui'",
    "playwright:update-snapshots": "start-server-and-test start-playwright-image tcp:5001 'PW_TEST_CONNECT_WS_ENDPOINT=ws://127.0.0.1:5001/ npx playwright test --update-snapshots'",
    "prebuild": "rm -rf .gh-pages",
    "build": "parcel build test/index.html",
    "cache:clear": "rm -rf .parcel-cache",
    "start": "npm run cache:clear && parcel test/index.html --port 3000",
    "deploy": "npm run build -- --no-cache --public-url \"/page-fragmentor/\" && gh-pages -d .gh-pages",
    "preversion": "npm run lint",
    "postpublish": "npm run deploy",
    "release": "npx np --any-branch"
  },
  "author": "Citizens Advice",
  "license": "ISC",
  "type": "module",
  "files": [
    "styles/**/*",
    "src/**/*"
  ],
  "exports": {
    ".": "./src/index.js",
    "./auto": "./src/auto.js",
    "./styles.css": "./styles/styles.css"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "parcel": "^2.16.4",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.7",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  },
  "prettier": {
    "singleAttributePerLine": true,
    "singleQuote": true
  },
  "targets": {
    "main": false,
    "default": {
      "distDir": ".gh-pages"
    }
  },
  "np": {
    "yarn": false
  }
}
